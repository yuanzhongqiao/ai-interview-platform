# ──────────────────────────────────────
# Supabase
# ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ──────────────────────────────────────
# App URL
# ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────
# LLM Providers
# ──────────────────────────────────────
# Configure at least one provider. Recommended OSS setup:
# - OPENAI_API_KEY for the main app features
# - GEMINI_API_KEY for relay summarization and as a low-latency fallback

# OpenAI
OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Google Gemini
GEMINI_API_KEY=

# Moonshot Kimi
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# MiniMax
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ──────────────────────────────────────
# Voice Relay
# ──────────────────────────────────────
VOICE_RELAY_PORT=8766
OPENAI_VOICE_RELAY_PORT=8767

# Browser-facing relay URLs. In production behind a reverse proxy, these can
# point to same-origin WebSocket paths such as /ws/voice and /ws/openai-voice.
NEXT_PUBLIC_VOICE_RELAY_URL=ws://localhost:8766
NEXT_PUBLIC_OPENAI_VOICE_RELAY_URL=ws://localhost:8767

# Primary relay preference: "auto" | "voice" | "openai"
# Recommended for best voice quality when Doubao credentials are configured.
NEXT_PUBLIC_VOICE_RELAY_PRIMARY=voice

# ──────────────────────────────────────
# Relay LLM
# ──────────────────────────────────────
# Used by the Volcengine voice relay for interviewer replies and context
# summarization. Defaults to Gemini and falls back to MiniMax when configured.
RELAY_LLM_PROVIDER=gemini
RELAY_LLM_MODEL=gemini-3.1-flash-lite
RELAY_LLM_TEMPERATURE=0
# Optional; falls back to GEMINI_API_KEY when RELAY_LLM_PROVIDER=gemini.
# RELAY_LLM_API_KEY=
# Only needed for OpenAI-compatible relay LLMs.
# RELAY_LLM_BASE_URL=
# RELAY_LLM_FALLBACK_MODEL=abab6.5s-chat
# RELAY_LLM_FALLBACK_BASE_URL=https://api.minimaxi.com/v1

# ──────────────────────────────────────
# Volcengine Doubao Voice Relay
# ──────────────────────────────────────
# Recommended primary relay. Use either:
# TTS：DOUBAO_APP_ID + DOUBAO_ACCESS_TOKEN
# ASR 2.0 新版：API Key 管理 → DOUBAO_ASR_API_KEY；TTS 用 APP_ID + ACCESS_TOKEN
DOUBAO_APP_ID=
DOUBAO_ACCESS_TOKEN=
DOUBAO_API_KEY=
DOUBAO_ASR_API_KEY=
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
DOUBAO_ASR_AUTH=api_key
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
DOUBAO_VOICE_EN=en_female_dacey_uranus_bigtts
DOUBAO_VOICE_ZH=zh_female_shuangkuaisisi_uranus_bigtts
DOUBAO_TTS_SPEECH_RATE=1
DOUBAO_TTS_PCM_SAMPLE_LAYOUT=int16le

# Optional ASR timing overrides. The defaults are tuned for natural interview
# pauses and should work well for most deployments.
# DOUBAO_ASR_END_WINDOW_MS=2000
# DOUBAO_ASR_FINAL_COALESCE_MS=2200
# DOUBAO_ASR_LONG_FINAL_COALESCE_MS=5000
# DOUBAO_ASR_SHORT_FINAL_COALESCE_MS=500
# DOUBAO_ASR_ACTIVE_SPEECH_HOLD_MS=1200
# DOUBAO_ASR_PENDING_FINAL_QUIET_MS=1600

# ──────────────────────────────────────
# Azure OpenAI Realtime Voice Relay
# ──────────────────────────────────────
# Backup relay for environments without Doubao credentials.
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-realtime-1.5
# AZURE_OPENAI_VOICE=ash

# ASR provider used by the Azure OpenAI relay: "openai" | "volc"
# Keep "openai" unless you want the Azure relay to use Doubao ASR.
# VOICE_ASR_PRIMARY=openai
# OPENAI_REALTIME_TRANSCRIPTION_MODEL=whisper-1

# ──────────────────────────────────────
# AI Chat (frontend defaults; users can override in /ai-chat settings)
# ──────────────────────────────────────
NEXT_PUBLIC_AI_API_BASE_URL=http://api.gitcc.com/v1
# NEXT_PUBLIC_AI_API_KEY=
NEXT_PUBLIC_AI_MODEL=gpt-4.1
NEXT_PUBLIC_AI_SYSTEM_NAME=聆悟

# ──────────────────────────────────────
# Branding (header logo, wordmark, browser tab, favicon)
# ──────────────────────────────────────
NEXT_PUBLIC_BRAND_NAME=聆悟
NEXT_PUBLIC_BRAND_NAME_EN=Lingwu
NEXT_PUBLIC_BRAND_MARK=聆悟
NEXT_PUBLIC_BRAND_MARK_EN=Lingwu
# NEXT_PUBLIC_BRAND_TAGLINE=结构化语音、文字与视频 AI 面试平台
# NEXT_PUBLIC_BRAND_TAGLINE_EN=AI interview platform for structured voice, chat, and video interviews.
# Paths under public/ (改后须重新 build web)
# 品牌图标写死在 src/lib/brand.ts，勿配置 NEXT_PUBLIC_BRAND_LOGO_URL / FAVICON

# ──────────────────────────────────────
# Docker 全量部署（线上 Supabase，见 docker-compose.yaml）
# ──────────────────────────────────────
# 复制本文件为 .env.local 并填入线上 Supabase 后执行:
#   pnpm run docker:full
# 访问 http://localhost:4010 ，语音 ws://localhost:4011
# NEXT_PUBLIC_APP_URL=http://localhost:4010
# NEXT_PUBLIC_VOICE_RELAY_URL=ws://localhost:4011

# ──────────────────────────────────────
# Next.js Server Actions（Docker/生产必填，生成一次后勿改）
# ──────────────────────────────────────
# 生成: openssl rand -base64 32
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ──────────────────────────────────────
# Optional
# ──────────────────────────────────────
# LOG_LEVEL=info
