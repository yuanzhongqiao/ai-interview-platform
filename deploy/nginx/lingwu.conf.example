# 与 lingwu.conf 相同，供仓库模板；生产请用 lingwu.conf
# 见 deploy/nginx/README.md

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream lingwu_web {
    server 127.0.0.1:4010;
    keepalive 32;
}

upstream lingwu_voice {
    server 127.0.0.1:4011;
    keepalive 8;
}

server {
    listen 80;
    server_name gitgg.com www.gitgg.com;

    client_max_body_size 50m;

    if ($host = www.gitgg.com) {
        return 301 http://gitgg.com$request_uri;
    }

    location / {
        proxy_pass http://lingwu_web;
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection        "";

        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}

server {
    listen 80;
    server_name voice.gitgg.com;

    location / {
        proxy_pass http://lingwu_voice;
        proxy_http_version 1.1;

        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host       $host;
        proxy_set_header X-Real-IP  $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_buffering off;
    }
}
