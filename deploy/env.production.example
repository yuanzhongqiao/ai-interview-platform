# 复制为服务器 /opt/lingwu/.env.local 或 deploy/env.production（含密钥，勿提交 Git）
# 与 deploy/nginx/lingwu.conf 对齐后，须重新 build web 镜像

# ── Supabase（线上）──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── 对外 URL（Nginx HTTP）──
NEXT_PUBLIC_APP_URL=http://gitgg.com
# 语音子域（HTTPS 页面用 wss://；仅 HTTP 证书未配时暂用 ws://voice.gitgg.com）
NEXT_PUBLIC_VOICE_RELAY_URL=wss://voice.gitgg.com
NEXT_PUBLIC_OPENAI_VOICE_RELAY_URL=wss://voice.gitgg.com
NEXT_PUBLIC_VOICE_RELAY_PRIMARY=voice

# ── LLM ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
GEMINI_API_KEY=dummy
AI_REPORT_MODEL=deepseek-v4-pro
AI_GENERATOR_MODEL=deepseek-v4-flash

# ── 语音中继 ──
VOICE_RELAY_PORT=8766
RELAY_LLM_API_KEY=
RELAY_LLM_BASE_URL=https://api.deepseek.com/v1
RELAY_LLM_MODEL=deepseek-v4-flash
RELAY_LLM_TEMPERATURE=0

# ── 豆包 ──
DOUBAO_APP_ID=
DOUBAO_ACCESS_TOKEN=
DOUBAO_API_KEY=
# ASR 新版控制台：API Key 管理 → DOUBAO_ASR_API_KEY（不是实例页 Secret Key）
DOUBAO_ASR_API_KEY=
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
DOUBAO_ASR_AUTH=api_key
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
DOUBAO_VOICE_ZH=zh_female_shuangkuaisisi_uranus_bigtts
DOUBAO_VOICE_EN=en_female_dacey_uranus_bigtts

# ── 品牌 ──
NEXT_PUBLIC_BRAND_NAME=聆悟
NEXT_PUBLIC_BRAND_NAME_EN=Lingwu
NEXT_PUBLIC_BRAND_MARK=聆悟
# 品牌图标已写死在 src/lib/brand.ts（/brand-icons/lingwu-icon-ear-analytics.png），无需配置

# 生成一次后固定不变: openssl rand -base64 32（勿随意更换，否则 Server Action 会失效）
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=Dea2fl0FMWmW2FGf3N8wOCiWw648annc5W4uq/RFbG4=

NODE_ENV=production
LOG_LEVEL=info
